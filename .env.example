# =============================================================================
# AGRARIAN — Pipeline Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# Variables left empty or commented out use the built-in defaults.
# pydantic-settings reads variables case-insensitively.
#
# Internal tuning constants (queue sizes, timeouts, retry counts) are fixed
# in src/shared/processes/constants.py and are not configurable via env vars.
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION MODE  (required)
# Supported values: danger_detection, health_monitoring
# -----------------------------------------------------------------------------
APP_MODE=danger_detection

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
# ALERTS_COOLDOWN_SECONDS=1.0

# -----------------------------------------------------------------------------
# DRONE HARDWARE
# Default values match the DJI Mavic 3 Enterprise 4/3 CMOS sensor.
# https://sdk-forum.dji.net/hc/en-us/articles/12325496609689-What-is-the-custom-camera-parameters-for-Mavic-3-Enterprise-series-and-Mavic-3M
# Important: Sensor dimensions must satisfy: width_mm/height_mm == width_px/height_px
# -----------------------------------------------------------------------------
# DRONE_TRUE_FOCAL_LEN_MM=12.29
# DRONE_SENSOR_WIDTH_MM=17.35
# DRONE_SENSOR_HEIGHT_MM=13.00
# DRONE_SENSOR_WIDTH_PIXELS=5280
# DRONE_SENSOR_HEIGHT_PIXELS=3956

# -----------------------------------------------------------------------------
# DANGER DETECTION PARAMETERS
# -----------------------------------------------------------------------------
# SAFETY_RADIUS_M=2.0
# SLOPE_ANGLE_THRESHOLD=30.0

# Geofencing polygon — comma-separated (longitude, latitude) pairs, at least 3.
# Leave empty or unset to disable geofencing.
# GEOFENCING_VERTEXES=(8.87, 44.41), (8.89, 44.41), (8.89, 44.42), (8.87, 44.42)

# -----------------------------------------------------------------------------
# VIDEO STREAM READER  (drone → pipeline)
# Supported protocols: rtsp, rtmp, rtmps (requires credentials), rtsps (requires credentials)
# The full URL is assembled as: PROTOCOL://[USER:PASS@]HOST:PORT/STREAM_KEY
# -----------------------------------------------------------------------------
# VIDEO_STREAM_READER_PROTOCOL=rtsp
VIDEO_STREAM_READER_HOST=172.17.0.1
VIDEO_STREAM_READER_PORT=8554
VIDEO_STREAM_READER_STREAM_KEY=drone
# Required only for rtmps / rtsps:
# VIDEO_STREAM_READER_USERNAME=
# VIDEO_STREAM_READER_PASSWORD=

# -----------------------------------------------------------------------------
# TELEMETRY / MQTT  (drone telemetry → pipeline)
# Supported protocols: mqtt, mqtts (requires credentials + CA cert in certificates/mqtt/)
# -----------------------------------------------------------------------------
# TELEMETRY_LISTENER_PROTOCOL=mqtt
TELEMETRY_LISTENER_HOST=172.17.0.1
TELEMETRY_LISTENER_PORT=1883
# Required only for mqtts:
# TELEMETRY_LISTENER_USERNAME=
# TELEMETRY_LISTENER_PASSWORD=

# TELEMETRY_LISTENER_QOS_LEVEL=1

# -----------------------------------------------------------------------------
# HEALTH MONITORING — ANOMALY DETECTION
# -----------------------------------------------------------------------------
# HM_ANOMALY_USE_AE=true
# HM_ANOMALY_USE_SOCIAL=true
# HM_ANOMALY_AE_THRESHOLD=2.75
# HM_ANOMALY_SOCIAL_THRESHOLD=5.0
# HM_ANOMALY_SMOOTHING_WINDOW=56
# HM_ANOMALY_MIN_ANOMALY_DURATION=90
# HM_ANOMALY_SOCIAL_EMA_ALPHA=0.007
# HM_ANOMALY_SOCIAL_MIN_UPDATES=375
# HM_ANOMALY_SOCIAL_MIN_HERD=5
# HM_ANOMALY_REQUIRE_BOTH=false

# -----------------------------------------------------------------------------
# ALERTS WRITER
# -----------------------------------------------------------------------------
# ALERTS_JPEG_COMPRESSION_QUALITY=85

# -----------------------------------------------------------------------------
# WEBSOCKET SERVER  (alerts → UI)
# Set WEBSOCKET_HOST to 0.0.0.0 to bind on all interfaces (default).
# -----------------------------------------------------------------------------
# WEBSOCKET_HOST=0.0.0.0
# WEBSOCKET_PORT=8443

# -----------------------------------------------------------------------------
# DATABASE  (alert storage — leave DB_SERVICE empty to disable)
# Supported services: postgresql, mysql, sqlite
# DB_WORKER_NAME / DB_WORKER_PASSWORD: DB connection role (used in the SQLAlchemy URL)
# DB_USERNAME / DB_PASSWORD: app-level credentials checked against the users table
# -----------------------------------------------------------------------------
# DB_SERVICE=postgresql
# DB_HOST=172.17.0.1
# DB_PORT=5432
# DB_NAME=agrarian_db
# DB_WORKER_NAME=app_manager
# DB_WORKER_PASSWORD=
# DB_USERNAME=
# DB_PASSWORD=

# -----------------------------------------------------------------------------
# VIDEO STREAM OUTPUT  (annotated video → media server via FFmpeg/RTMP)
# The full URL is assembled as: PROTOCOL://[USER:PASS@]HOST:PORT/STREAM_KEY
# Supported protocols: rtmp, rtmps (requires credentials)
# -----------------------------------------------------------------------------
# VIDEO_OUT_STREAM_PROTOCOL=rtmp
VIDEO_OUT_STREAM_HOST=172.17.0.1
VIDEO_OUT_STREAM_PORT=1935
VIDEO_OUT_STREAM_STREAM_KEY=annot
# Required only for rtmps:
# VIDEO_OUT_STREAM_USERNAME=
# VIDEO_OUT_STREAM_PASSWORD=

# -----------------------------------------------------------------------------
# VIDEO STORAGE  (upload recorded video after session ends)
# Supported services: local, azure, aws
#   local  — copy to VIDEO_OUT_STORE_LOCAL_TARGET_DIR (default, for testing)
#   azure  — requires AZURE_CONNECTION_STRING + AZURE_CONTAINER_NAME
#   aws    — requires AWS_BUCKET_NAME; credentials optional (falls back to IAM/env)
# -----------------------------------------------------------------------------
# VIDEO_OUT_STORE_SERVICE=local
# VIDEO_OUT_STORE_DELETE_LOCAL_ON_SUCCESS=true

# Local storage
# VIDEO_OUT_STORE_LOCAL_TARGET_DIR=processing_results

# Azure Blob Storage
# VIDEO_OUT_STORE_AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# VIDEO_OUT_STORE_AZURE_CONTAINER_NAME=agrarian-videos
# VIDEO_OUT_STORE_AZURE_BLOB_PREFIX=

# AWS S3
# VIDEO_OUT_STORE_AWS_BUCKET_NAME=agrarian-videos
# VIDEO_OUT_STORE_AWS_KEY_PREFIX=
# VIDEO_OUT_STORE_AWS_ACCESS_KEY_ID=
# VIDEO_OUT_STORE_AWS_SECRET_ACCESS_KEY=
# VIDEO_OUT_STORE_AWS_REGION_NAME=
