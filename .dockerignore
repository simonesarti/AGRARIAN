# Git
.git
.gitignore
.gitattributes

# Operating System specific
.DS_Store

# Byte-compiled / optimized / DLL files
**/__pycache__/
**/*.py[cod]

# C extensions
*.so

# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# Virtual environment
.env
.env.example
.venv/
venv/

# IDEs
.idea/
.vscode/

# Test / dev artifacts
tests/
.pytest_cache/

# Project specific directories
assets/
experiments/
outputs/

# Logs — never bake log files into the image
logs/

# Exclude all src subdirs, then re-include only what is needed
src/*/
!src/danger_detection/
!src/health_monitoring/
!src/shared/

# Exclude all configs subdirs, then re-include only what is needed
configs/*/
!configs/danger_detection/
!configs/health_monitoring/

# Root-level Python files — exclude dev/utility scripts, keep pipeline entrypoints
*.py
!main.py
!danger_detection_stream.py
!health_monitoring_stream.py

# Shell scripts
*.sh
