# =============================================================================
# DB Writer Sidecar — Operator Configuration
# =============================================================================
# OPERATOR ONLY — do not share with end users.
# This file holds the privileged DB worker credentials that grant the sidecar
# read/write access to the database on behalf of authenticated app users.
#
# Copy to db_writer/.env and fill in the values before deploying.
# =============================================================================

DB_SERVICE=postgresql
DB_HOST=172.17.0.1
DB_PORT=5432
DB_NAME=agrarian_db
DB_WORKER_NAME=app_manager
DB_WORKER_PASSWORD=
