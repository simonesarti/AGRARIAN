# =============================================================================
# DB Writer Sidecar — standalone configuration (outside docker-compose)
# =============================================================================
# When running via docker-compose, these values are injected by the compose file.
# This file is used only when running the sidecar standalone against an external DB.
#
# Copy to db_writer/.env and fill in the values before running standalone.
# =============================================================================

DB_SERVICE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agrarian_db
DB_WORKER_NAME=db_user
DB_WORKER_PASSWORD=
